Options -Indexes
DirectoryIndex index.php index.html
RewriteEngine On

# Support legacy /reclaim-system/... links when the app is deployed at the domain root.
RewriteCond %{REQUEST_URI} ^/reclaim-system(?:/(.*))?$ [NC]
RewriteCond %{DOCUMENT_ROOT}/reclaim-system !-d
RewriteRule ^reclaim-system/?(.*)$ $1 [L,QSA]

# Security: never serve config files or secrets directly from the browser.
RewriteRule ^config(/|$) - [F,L]
RewriteRule ^(\.env|\.git|composer\.(json|lock)) - [F,L]

# Allow all access to assets folder (no rewriting)
RewriteRule ^assets/ - [L]

# If file exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If directory exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route .php files without extension
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]

# Everything else to index.php
RewriteRule ^ index.php [L]
