RewriteEngine On
RewriteBase /reclaim-system/

# Security: never serve config files or secrets directly from the browser.
RewriteRule ^config(/|$) - [F,L]
RewriteRule ^(\.env|\.git|composer\.(json|lock)) - [F,L]

# Allow all access to assets folder (no rewriting)
RewriteRule ^assets/ - [L]

# If file exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If directory exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route .php files without extension
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]

# Everything else to index.php
RewriteRule ^ index.php [L]
